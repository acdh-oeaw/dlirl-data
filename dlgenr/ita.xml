  <text>
      <body>
         <entry xml:id="ita-dlgenr"
            xml:lang="en"
            type="mainEntry"
            prev="#"
            next="#"
            source="Genesis Rabbah">
            <form type="lemma" opt="false">
               <orth type="lemma" xml:lang="jpa" opt="false" select="true">איטא</orth>
               <orth type="transliteration" xml:lang="fjb" opt="false">ʾyṭh</orth>
               <pron notation="rabbinic" opt="false">iṭaʾ</pron>
               <gramGrp opt="false">
                  <gram type="pos" opt="false">noun</gram>
                  <gram type="gen">f.</gram>
               </gramGrp>
            </form>
            <form type="variant" opt="false">
               <orth type="variant" xml:lang="jpa" opt="false" select="true">איטה</orth>
               <orth type="transliteration" xml:lang="fjb" opt="false">ʾyṭh</orth>
               <pron notation="rabbinic" opt="false">iṭah</pron>
               <gramGrp opt="false">
                  <gram type="pos" opt="false">noun</gram>
                  <gram type="gen">f.</gram>
               </gramGrp>
            </form>
            <form type="variant">
               <orth type="variant">היטה</orth>
               <orth type="transliteration" xml:lang="fjb">hyṭh</orth>
               <pron notation="rabbinic">hiṭah</pron>
               <gramGrp>
                  <gram type="pos">noun</gram>
                  <gram type="gen">f.</gram>
               </gramGrp>
            </form>
            <sense xml:id="ita-dlgenr-1">
               <cit type="translation" xml:lang="jpa" subtype="sense">
                  <quote>letter eta</quote></cit>
               <cit type="translationEquivalent">
                  <quote xml:lang="grc">ήτα</quote>
               </cit>
               <cit type="example" xml:lang="jpa">
                  <quote>אמר להון מדידכון אנא ממטי לכון זיטא איפטה 
                     <app>
                        <lem>איטה</lem>
                        <rdg wit="#Vat2 Ox2 V">איטא</rdg>
                     </app> אכטו</quote>
                  <bibl>
                     <ref type="witness">14,2</ref>
                     <ref type="witness">I 127: 3</ref>
                  </bibl>
                  <ref type="entry" xml:lang="jpa">אכטו</ref>
                  <ref type="entry" xml:lang="jpa">זיטא</ref>
                  <ref type="entry" xml:lang="jpa">איפטה</ref>
                  <cit type="translation" xml:lang="en">
                     <quote>He replied to them: From your own [language] I will prove it to you: “Zeṭaʾ (live) epṭah (seven), eṭah (go) akṭo (eight)” (cf. Freedman / Simon I: 112)</quote>
                  </cit>
               </cit>
               <cit type="example" xml:lang="jpa">
                  <quote>אמר להון מדידכון אנה ממטי לכון זיטא איפטה 
                     <app>
                        <lem>היטה</lem>
                        <rdg wit="#Vat1">איטא</rdg>
                        <rdg wit="#K">איטה</rdg>
                     </app> אוקטון</quote>
                  <bibl>
                     <ref type="witness">20,6</ref>
                     <ref type="witness">I 189: 3</ref>
                  </bibl>
                  <ref type="entry" xml:lang="jpa">אוקטון</ref>
                  <ref type="entry" xml:lang="jpa">זיטא</ref>
                  <ref type="entry" xml:lang="jpa">איפטה</ref>
                  <cit type="translation" xml:lang="jpa">
                     <quote>He replied to them: From your own [language] I will prove it to you: “Zetaʾ (live) epṭah (seven), eṭah (go) akṭo (eight)” (cf. Freedman / Simon I: 164)</quote>
                  </cit>
               </cit>
            </sense>
            <note>= <bibl type="ancient">Yalq Bereshit 20 [6c: 54]</bibl>; <bibl type="ancient">NumR 4,3</bibl>; <bibl type="ancient">TanhB Bemidbar 21</bibl>; <bibl type="ancient">Yalq 692 [VII 16: 32]</bibl>; <bibl type="ancient">Tanh Bemidbar 18</bibl> (corr.) <term xml:lang="jpa">אוטה</term> <term xml:lang="fjb">ʾwṭn</term>; <bibl type="ancient">yYev 5d: 7</bibl> - (corr.) Explanation cf. <ref type="entry" xml:lang="jpa" target="zeta.html">זיטא</ref></note>
            <ref type="bibliography">
               <bibl>
                  <title>Krauss, LW II</title>
                  <citedRange>31b</citedRange>
               </bibl>
            </ref>
         </entry>
