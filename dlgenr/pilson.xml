            <form type="lemma" opt="false">
               <orth type="lemma" xml:lang="jpa" opt="false" select="true">פילסון</orth>
               <orth type="transliteration" xml:lang="fjb" opt="false">pylswn</orth>
               <pron notation="rabbinic" opt="false">pilason</pron>
               <gramGrp opt="false">
                  <gram type="pos" opt="false">noun</gram>
                  <gram type="gen" opt="false">m.</gram>
               </gramGrp>
            </form>
            <sense xml:id="pilson-dlgenr-1">
               <cit type="translation" xml:lang="en" subtype="sense">
                  <quote>guardian</quote>
               </cit>
               <cit type="translationEquivalent" xml:lang="grc">
                  <quote>φυλάσσων</quote>
               </cit>
               <cit type="example" xml:lang="jpa">
                  <quote>הנה בעל החלומות הלזה בא, רבנין אמ' הוא 
                     <app>
                        <lem>פילסונו</lem>
                        <rdg wit="#K V Ox1 Ox2">ופלסונו</rdg>
                     </app>, הלזה אליו זה.</quote>
                  <bibl>
                     <ref type="witness">60,15</ref>
                     <ref type="witness">II 656: 1</ref>
                  </bibl>
                  <ref type="entry" xml:lang="jpa">אליו</ref>
                  <cit type="translation" xml:lang="en">
                     <quote>Behold, this [ha-la-zeh] dreamer cometh (Gen 37,19). The Rabbis said: This is his guardian [angel]; ha-la-zeh - this is another one.</quote>
                  </cit>
                  <note>= <bibl type="ancient">Yalq 109 [II 495: 38]</bibl></note>
               </cit>
            </sense>
            <ref type="bibliography">
               <bibl>
