  <text>
      <body>
         <entry xml:id="hatlis-dlgenr"
            xml:lang="en"
            type="mainEntry"
            prev="#"
            next="#"
            source="Genesis Rabbah">
            <form type="lemma" opt="false">
               <orth type="lemma" xml:lang="jpa" opt="false" select="true">הטליס</orth>
               <orth type="transliteration" xml:lang="fjb" opt="false">hṭlys</orth>
               <pron notation="rabbinic" opt="false">haṭlis</pron>
               <gramGrp opt="false">
                  <gram type="pos" opt="false">noun</gram>
                  <gram type="gen" opt="false">m.</gram>
               </gramGrp>
               <form type="variant">
                  <orth type="variant" xml:lang="jpa">אטליס</orth>
                  <orth type="transliteration" xml:lang="fjb">ʾṭlys</orth>
                  <pron notation="rabbinic">ʾaṭlis</pron>
               </form>
            </form>
            <sense xml:id="hatlis-dlgenr-1">
               <cit type="translation" xml:lang="en" subtype="sense">
                  <quote>unaccomplished, alone, free, unmarried</quote>
               </cit>
               <cit type="translationEquivalent" xml:lang="grc">
                  <quote>ἀτελής</quote>
               </cit>
               <cit type="example" xml:lang="jpa">
                  <quote>או שמא אני מתה ואת יושב לך 
                     <app>
                        <lem>היטליס</lem>
                        <rdg wit="#V">הטליס</rdg>
                        <rdg wit="#K">אטליס</rdg>
                     </app></quote>
                  <bibl>
                     <ref type="witness">19,5</ref>
                     <ref type="witness">I 174: 7</ref>
                  </bibl>
                  <cit type="translation" xml:lang="en">
                     <quote>... maybe I will die and you will remain unmarried.</quote>
                  </cit>
                  <note>= <bibl type="ancient">Yalq 27 [I 93: 30]</bibl> (<term xml:lang="jpa">אטליס</term>)</note>
               </cit>
               <cit type="example" xml:lang="jpa">
                  <quote>או שאני מתה ואת יושב לך 
                     <app>
                        <lem>היטליס</lem>
                        <rdg wit="#V">הטליס</rdg>
                        <rdg wit="#K">איטליס</rdg>
                        <rdg wit="#Vat1">היטיליס</rdg>
                     </app></quote>
                  <bibl>
                     <ref type="witness">20,8</ref>
                     <ref type="witness">I 191: 12</ref>
                  </bibl>
                  <cit type="translation" xml:lang="en">
                     <quote>... maybe I will die and you will remain unmarried.</quote>
                  </cit>
               </cit>
               <cit type="example" xml:lang="jpa">
                  <quote>א"ל הק' הטליס, חייך אני מגרה בך את הדוב</quote>
                  <bibl>
                     <ref type="witness">87,4</ref>
                     <ref type="witness">III 1064: 2</ref>
                  </bibl>
                  <cit type="translation" xml:lang="en">
                     <quote>... The Lord said to him: [You are] alone [now], by your life: I will incite the she-bear against you.</quote>
                  </cit>
                  <note>= <bibl type="ancient">Yalq 145 [II 750: 43]</bibl> (<term xml:lang="jpa">הטלס</term>); <bibl type="ancient">Yalq Job 920 [509: 4]</bibl></note>
               </cit>
            </sense>
            <note>Cf. <bibl type="modern">Levy I 462b</bibl>; <bibl type="modern">AC III 198ab</bibl>. For GenR 87,4 cf. <ref type="entry" xml:lang="jpa">איטוליס</ref>.</note>
            <ref type="bibliography">
               <bibl>
                  <title>Krauss, LW II</title>
                  <citedRange>225b</citedRange>
               </bibl>
            </ref>
         </entry>
      </body>
