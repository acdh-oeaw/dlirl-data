  <text>
      <body>
         <entry xml:id="istrateq-ys"
            type="mainEntry"
            xml:lang="en"
            prev="#estrateg-ys"
            next="#askolastiqa-dlgenr"
            source="Yalkut Shimoni">
            <form type="lemma">
               <orth type="lemma" xml:lang="jpa" opt="false" select="true">אסטרטיג</orth>
               <orth type="transliteration" xml:lang="fjb" opt="false">ʾsṭrṭyg</orth>
               <pron notation="rabbinic" opt="false">isṭraṭeg</pron>
               <gramGrp>
                  <gram type="pos">noun</gram>
                  <gram type="gen">m.</gram>
               </gramGrp>
               <form type="variant">
                  <orth type="variant" xml:lang="jpa">איסטרטיג</orth>
                  <orth type="transliteration" xml:lang="fjb">ʾysṭrṭyg</orth>
                  <pron notation="rabbinic">isṭraṭeg</pron>
               </form>
               <form type="inflected">
                  <orth type="inflected" xml:lang="jpa">אסטרטיגין</orth>
                  <orth type="transliteration" xml:lang="fjb">ʾsṭrṭygyn</orth>
                  <pron notation="rabbinic">isṭrategin</pron>
                  <gramGrp>
                     <gram type="num">pl.</gram>
                  </gramGrp>
               </form>
               <form type="variant">
                  <orth type="variant" xml:lang="jpa">איסטרטיגין</orth>
                  <orth type="transliteration" xml:lang="fjb">ʾysṭrṭygyn</orth>
                  <pron notation="rabbinic">isṭrategin</pron>
                  <gramGrp>
                     <gram type="num">pl.</gram>
                  </gramGrp>
               </form>
            </form>
            <sense xml:id="istrateg-ys-1">
               <cit type="translation" xml:lang="en" subtype="sense">
                  <quote>prefect, magistrate</quote>
               </cit>
               <cit type="translationEquivalent" xml:lang="grc">
                  <quote>στρατηγός</quote>
               </cit>
               <cit type="example" xml:lang="jpa">
                  <quote>... למלך שהיו חו שני איסטרטיגין</quote>
                  <bibl>
                     <ref type="witness">Yalq 5</ref>
                     <ref type="witness">I 18: 6</ref>
                  </bibl>
                  <cit type="translation" xml:lang="en">
                     <quote>... this is comparable to a king who had two prefects</quote>
                  </cit>
                  <note>= <bibl type="ancient">GenR 3,6 [I 22: 7]</bibl>; <bibl type="ancient">Yalq Jes 462 [XI 225: 27]</bibl>; <bibl type="ancient">Yalq Hi 925 [510b: 60]</bibl>; <bibl type="ancient">yBer 8,6 [63: 44]</bibl>; <bibl type="ancient">YalkM Jes 45,7 [151: 26]</bibl> (<term xml:lang="jpa">אצטרטיגין</term>)</note>
               </cit>
               <cit type="example" xml:lang="jpa">
                  <quote>גדולה, זו יון. ר' סימון או' שהיא מעמדת ק"כ דוכסין, ק"כ איפרכין, ק"כ אסטרדיוטין [אסטרטיגין?]</quote>
                  <bibl>
                     <ref type="witness">Yalq 77</ref>
                     <ref type="witness">I 308: 88</ref>
                  </bibl>
                  <ref type="entry" xml:lang="jpa">איפרכין</ref>
                  <ref type="entry" xml:lang="jpa">דוכסין</ref>
                  <cit type="translation" xml:lang="en">
                     <quote>What does it resemble? A human king who entered the province together with commanders, prefects and governors. Although they all entered through the same gate, but every one lined up according to his honour.</quote>
                  </cit>
                  <note>= <bibl type="ancient">GenR 44,17 [I 440: 1]</bibl> (<ref type="entry" xml:lang="jpa">איסטרטלין</ref>); <bibl type="ancient">LevR Shemini 13,5</bibl>; <bibl type="ancient">LeqT Gen 15,12 [35b]</bibl></note>
               </cit>
            </sense>
            <note>Cf. GenR <ref type="entry" xml:lang="jpa" target="istrateg.html">אסטרטיג</ref></note>
            <ref type="bibliography">
               <bibl>
                  <title>Sokoloff, DJPA</title>
                  <citedRange>25b</citedRange>
               </bibl>
               <bibl>
                  <title>Krauss, LW II</title>
                  <citedRange>83ab</citedRange>
               </bibl>
            </ref>
         </entry>
