      <body>
         <entry xml:id="askolasiqah-ys"
            type="mainEntry"
            xml:lang="en"
            prev="#"
            next="#"
            source="Yalkut Shimoni">
            <form type="lemma">
               <orth type="lemma" xml:lang="jpa" opt="false" select="true">אסכולסטיקה</orth>
               <orth type="transliteration" xml:lang="fjb" opt="false">ʾskwlsṭykh</orth>
               <pron notation="rabbinic" opt="false">askolasṭiqah</pron>
               <gramGrp>
                  <gram type="pos">noun</gram>
                  <gram type="gen">m.</gram>
               </gramGrp>
               <form type="variant">
                  <orth type="variant" xml:lang="jpa">אסכולסטיקא</orth>
                  <orth type="transliteration" xml:lang="fjb">ʾskwlsṭykʾ</orth>
                  <pron notation="rabbinic">askolasṭiqaʾ</pron>
               </form>
               <form type="variant">
                  <orth type="variant" xml:lang="jpa">אסקלוסתיקא</orth>
                  <orth type="transliteration" xml:lang="fjb">ʾsqwlwstyqʾ</orth>
                  <pron notation="rabbinic">asqolostiqaʾ</pron>
               </form>
               <form type="inflected">
                  <orth type="inflected" xml:lang="jpa">אסכולסטיקין</orth>
                  <orth type="transliteration" xml:lang="fjb">ʾskwlsṭyqyn</orth>
                  <pron notation="rabbinic">askolasṭiqin</pron>
                  <gramGrp>
                     <gram type="num">pl.</gram>
                  </gramGrp>
               </form>
            </form>
            <sense xml:id="askolastiqah-ys-1">
               <cit type="translation" xml:lang="en" subtype="sense">
                  <quote>scholar, advocate</quote>
               </cit>
               <cit type="translationEquivalent" xml:lang="grc">
                  <quote>σχολαστικός</quote>
               </cit>
               <cit type="example" xml:lang="jpa">
                  <quote>אמרין יעול ר' יהושע בן חנני' דהוא 
                     <app>
                        <lem>איסקוליתא</lem>
                        <rdg wit="#S">אסקלוסתיקא</rdg>
                     </app> דאוריתא</quote>
                  <bibl>
                     <ref type="witness">Yalq 111</ref>
                     <ref type="witness">II 534: 28</ref>
                  </bibl>
                  <cit type="translation" xml:lang="en">
                     <quote>Shall come R. Yehoshuaʿ ben Ḥananiyyaʾ, who is a scholar of the Law ...</quote>
                  </cit>
                  <note>= <bibl type="ancient">GenR 64,7 [II 712: 2]</bibl> (<term xml:lang="jpa">אסכולוסטיקה</term>)</note>
               </cit>
            </sense>
            <note>Cf. GenR <ref type="entry" xml:lang="jpa" target="askolastiqa.html">אסכולסטיקה</ref></note>
         </entry>
