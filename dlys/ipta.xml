  <text>
      <body>
         <entry xml:id="ipta-ys"
            type="mainEntry"
            xml:lang="en"
            prev="#epta-dlgenr"
            next="#aipaitin-ys"
            source="Yalkut Shimoni">
            <form type="lemma">
               <orth type="lemma" xml:lang="jpa" opt="false" select="true">איפטה</orth>
               <orth type="transliteration" xml:lang="fjb" opt="false">ʾypṭh</orth>
               <pron notation="rabbinic" opt="false">epṭah</pron>
               <gramGrp>
                  <gram type="pos">num.</gram>
               </gramGrp>
               <form type="variant">
                  <orth type="variant" xml:lang="jpa">איפטא</orth>
                  <orth type="transliteration" xml:lang="fjb">ʾypṭʾ</orth>
               </form>
               <form type="variant">
                  <orth type="variant" xml:lang="jpa">אפטא</orth>
                  <orth type="transliteration" xml:lang="fjb">ʾpṭʾ</orth>
                  <pron notation="rabbinic">epṭaʾ</pron>
               </form>
            </form>
            <sense xml:id="ipty-ys-1">
               <cit type="translation" xml:lang="en" subtype="sense">
                  <quote>seven</quote>
               </cit>
               <cit type="translationEquivalent" xml:lang="grc">
                  <quote>ἑπτά</quote>
               </cit>
               <cit type="example" xml:lang="jpa">
                  <quote>בעון קומי ר' אבהו מנין שהנוצר לשבעה חי אמ' לון מדידכון אנא, מדידכון אנא ממטי לכון זיטא-איפטא, איטא-אוקטו</quote>
                  <bibl>
                     <ref type="witness">Yalq 20</ref>
                     <ref type="witness">I 64: 82</ref>
                  </bibl>
                  <ref type="entry" xml:lang="jpa">זיטא</ref>
                  <ref type="entry" xml:lang="jpa">איטא</ref>
                  <ref type="entry" xml:lang="jpa">אוקטו</ref>
                  <cit type="translation" xml:lang="en">
                     <quote>He replied to them: From your own [language] I will prove it to you: “Zeṭaʾ (live) epṭah (seven), eṭah (go) akṭo (eight)” (cf. Freedman / Simon I: 112)</quote>
                  </cit>
                  <note>= <bibl type="ancient">GenR 14,2 [I 127: 3]</bibl>; <bibl type="ancient">GenR 20,6 [I 189: 3]</bibl>; <bibl type="ancient">NumR 4,3</bibl>: <term xml:lang="jpa">איפטא</term> <term xml:lang="fjb">ʾypṭʾ</term> <term xml:lang="rabbinic">epṭaʾ</term>; <bibl type="ancient">Tanh  Bemidbar 18</bibl>; <bibl type="ancient">TanhB Bemidbar 21</bibl></note>
               </cit>
               <cit type="example" xml:lang="jpa">
                  <quote>אמ' להן בלשון יוונית זיטא איפטא, איטא אוקטו</quote>
                  <bibl>
                     <ref type="witness">Yalq 691</ref>
                     <ref type="witness">VII 16: 32</ref>
                  </bibl>
                  <ref type="entry" xml:lang="jpa">אוקטו</ref>
                  <ref type="entry" xml:lang="jpa">איטא</ref>
                  <ref type="entry" xml:lang="jpa">זיטא</ref>
                  <cit type="translation" xml:lang="en">
                     <quote>He replied to them: In the Greek language [they say]: “Zeṭaʾ (live) epṭah (seven), eṭah (go) akṭo (eight)”.</quote>
                  </cit>
                  <note>= <bibl type="ancient">GenR 14,2 [I 127: 3]</bibl>; <bibl type="ancient">GenR 20,6 [I 189: 3]</bibl>; <bibl type="ancient">NumR 4,3</bibl>: <term xml:lang="jpa">איפטא</term> <term xml:lang="fjb">ʾypṭʾ</term> <term xml:lang="rabbinic">epṭaʾ</term>; <bibl type="ancient">Tanh  Bemidbar 18</bibl>; <bibl type="ancient">TanhB Bemidbar 21</bibl></note>
               </cit>
            </sense>
            <note>Cf. GenR <ref type="entry" xml:lang="jpa">זיטא</ref></note>
            <ref type="bibliography">
               <bibl>
                  <title>Krauss, LW II</title>
                  <citedRange>103a</citedRange>
               </bibl>
            </ref>
         </entry>
